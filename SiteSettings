    },
    "bot_description": {
      "type": "string",
      "default": "The ultimate Discord bot for your server."
    },
    "bot_tagline": {
      "type": "string",
      "default": "Powerful. Simple. Free."
    },
    "discord_server_link": {
      "type": "string",
      "default": "https://discord.gg/"
    },
    "bot_invite_link": {
      "type": "string",
      "default": "https://discord.com/oauth2/authorize"
